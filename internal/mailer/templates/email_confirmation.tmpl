{{define "html"}}
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>{{.Subject}}</title>
    </head>
    <body style="font-family: Arial, sans-serif; line-height: 1.5;">

    <h2>{{.Subject}}</h2>

    <p>
        Hello,
        <strong>{{.FirstName}} {{.SecondName}}</strong>.
    </p>

    <p>
        {{.Message}}
    </p>

    <div style="
        font-size: 32px;
        font-weight: bold;
        letter-spacing: 6px;
        padding: 12px 0;
    ">
        {{.Code}}
    </div>

    <p>
        {{.Hint}}
    </p>

    <hr>

    <small>
        This is an automated message, please do not reply.
    </small>

    </body>
    </html>
{{end}}